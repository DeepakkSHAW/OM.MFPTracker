@page "/transactions"

@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services

@inject ITransactionRepo TransactionRepo
@inject IFolioRepo FolioRepo
@inject IMutualFundRepo FundRepo

<h3>Transactions</h3>

<div class="row mb-3">

    <div class="col-3">
        <label>Folio</label>
        <select class="form-select"
                @bind="selectedFolioId"
                @bind:after="OnFolioChanged">

            <option value="">All</option>

            @foreach (var f in folios)
            {
                <option value="@f.FolioId">@f.FolioName</option>
            }
        </select>
    </div>

    <div class="col-3">
        <label>Fund</label>
        <select class="form-select"
                @bind="selectedFundId"
                @bind:after="FilterChanged">

            <option value="">All</option>

            @foreach (var f in funds)
            {
                <option value="@f.Id">@f.SchemeName</option>
            }
        </select>
    </div>

    <div class="col-3">
        <label>Search</label>
        <input class="form-control"
               @bind="searchText"
               @bind:event="oninput"
               @bind:after="FilterChanged" />
    </div>

</div>

<table class="table table-striped">

    <thead>
        <tr>
            <th>Date</th>
            <th>Folio</th>
            <th>Fund</th>
            <th>Units</th>
            <th>NAV</th>
            <th>Amount</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var t in transactions)
        {
            <tr>
                <td>@t.TransactionDate.ToShortDateString()</td>
                <td>@t.Folio.FolioName</td>
                <td>@t.Fund.SchemeName</td>
                <td>@t.Units</td>
                <td>@t.Nav</td>
                <td>@t.Amount</td>
            </tr>
        }

    </tbody>

</table>

<div class="mt-3">

    <button class="btn btn-secondary"
            disabled="@(currentPage == 1)"
            @onclick="PrevPage">
        Previous
    </button>

    <span class="mx-3">Page @currentPage of @totalPages</span>

    <button class="btn btn-secondary"
            disabled="@(currentPage == totalPages)"
            @onclick="NextPage">
        Next
    </button>

</div>

@code {

    List<FundTransaction> transactions = new();
    List<Folio> folios = new();
    List<MutualFund> funds = new();

    int? selectedFolioId;
    int? selectedFundId;
    string? searchText;

    int currentPage = 1;
    int pageSize = 10;
    int totalPages;

    protected override async Task OnInitializedAsync()
    {
        folios = await FolioRepo.GetAllAsync();
        await LoadData();
    }

    async Task OnFolioChanged()
    {
        selectedFundId = null;

        if (selectedFolioId.HasValue)
        {
            var folio = folios.First(x => x.FolioId == selectedFolioId);
            funds = await FundRepo.GetByAmcAsync(folio.AmcId.Value);
        }
        else
        {
            funds = new();
        }

        await LoadData();
    }

    async Task FilterChanged()
    {
        currentPage = 1;
        await LoadData();
    }

    async Task LoadData()
    {
        var result = await TransactionRepo.GetPagedAsync(
            selectedFolioId,
            selectedFundId,
            TransactionType.Buy,
            searchText,
            currentPage,
            pageSize);

        transactions = result.Data;
        totalPages = (int)Math.Ceiling(result.TotalCount / (double)pageSize);
    }

    async Task PrevPage()
    {
        currentPage--;
        await LoadData();
    }

    async Task NextPage()
    {
        currentPage++;
        await LoadData();
    }

}