@page "/funds"
@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services
@inject IMutualFundRepo FundRepo
@inject NavigationManager NavManager
@inject IJSRuntime JS

@code {

    private List<MutualFund> funds = new();
    private int totalFunds;
    private int activeFunds;
    private int navAllowedFunds;
    private int txnAllowedFunds;

    private string? searchText;
    private int? selectedStatusId;
    private bool activeOnly;

    private List<OperationalStatus> statuses = new();

    protected override async Task OnInitializedAsync()
    {
        funds = await FundRepo.GetAllOrderedAsync();
        await ApplyFilter();
    }
    // private async Task Delete(int id)
    // {
    //     if (await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this fund?"))
    //     {
    //         await FundRepo.DeleteAsync(id);
    //         funds = await FundRepo.GetAllAsync();
    //     }
    // }
    private async Task Delete(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this fund?"))
            return;

        try
        {
            await FundRepo.DeleteAsync(id);
            await ApplyFilter();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
    }
    private void CalculateStats()
    {
        totalFunds = funds.Count;
        activeFunds = funds.Count(f => f.OperationalStatus?.Code == "ACTIVE");
        navAllowedFunds = funds.Count(f => f.OperationalStatus?.IsNavAllowed == true);
        txnAllowedFunds = funds.Count(f => f.OperationalStatus?.IsTransactionAllowed == true);
    }
    private async Task ApplyFilter()
    {
        funds = await FundRepo.SearchAsync(searchText, selectedStatusId, activeOnly);
        CalculateStats();
    }

}

<h3 class="mb-3">Mutual Fund Management</h3>

<div class="d-flex justify-content-between mb-3">
    <div class="text-muted">
        Total Funds: <strong>@funds.Count</strong>
    </div>

    <NavLink class="btn btn-primary" href="/funds/add">
        + Add Mutual Fund
    </NavLink>
</div>

<div class="row mb-3">

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <div class="text-muted">Total Funds</div>
                <div class="fs-4 fw-bold">@totalFunds</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-success-subtle">
            <div class="card-body text-center">
                <div class="text-muted">Active</div>
                <div class="fs-4 fw-bold">@activeFunds</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-info-subtle">
            <div class="card-body text-center">
                <div class="text-muted">NAV Allowed</div>
                <div class="fs-4 fw-bold">@navAllowedFunds</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-warning-subtle">
            <div class="card-body text-center">
                <div class="text-muted">Transactions Allowed</div>
                <div class="fs-4 fw-bold">@txnAllowedFunds</div>
            </div>
        </div>
    </div>

</div>

<div class="card mb-3">
    <div class="card-body">

        <div class="row g-2 align-items-end">

            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input class="form-control"
                       @bind="searchText"
                       @bind:event="oninput"
                       placeholder="Scheme / AMC / ISIN" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Status</label>
                <InputSelect class="form-control" @bind-Value="selectedStatusId">
                    <option value="">All</option>
                    @foreach (var s in statuses)
                    {
                        <option value="@s.Id">@s.Description</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-2">
                <div class="form-check mt-4">
                    <InputCheckbox class="form-check-input" @bind-Value="activeOnly" />
                    <label class="form-check-label">Active Only</label>
                </div>
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="ApplyFilter">
                    Apply
                </button>
            </div>

        </div>
    </div>
</div>

<table class="table table-hover align-middle table-bordered">
    <thead class="table-light">
        <tr>
            <th>Scheme</th>
            <th>AMC</th>
            <th>Category</th>
            <th>Status</th>
            <th>NAV</th>
            <th>Txn</th>
            <th style="width:140px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var fund in funds)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@fund.SchemeName</div>
                    <div class="text-muted small">@fund.SchemeCode</div>
                </td>

                <td>@fund.Amc?.Name</td>

                <td>
                    <span class="badge bg-light text-dark border">
                        @fund.MFCategory?.CategoryName
                    </span>
                </td>

                <td>
                    @if (fund.OperationalStatus?.Code == "ACTIVE")
                    {
                        <span class="badge bg-success">
                            @fund.OperationalStatus.Description
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            @fund.OperationalStatus?.Description
                        </span>
                    }
                </td>

                <td>
                    @if (fund.OperationalStatus?.IsNavAllowed == true)
                    {
                        <span class="text-success fw-semibold">✔</span>
                    }
                    else
                    {
                        <span class="text-danger">✖</span>
                    }
                </td>

                <td>
                    @if (fund.OperationalStatus?.IsTransactionAllowed == true)
                    {
                        <span class="text-success fw-semibold">✔</span>
                    }
                    else
                    {
                        <span class="text-danger">✖</span>
                    }
                </td>

                <td class="text-end">
                    <button class="btn btn-sm btn-outline-warning me-1"
                            @onclick="@(() => NavManager.NavigateTo($"/funds/edit/{fund.Id}"))">
                        Edit
                    </button>

                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="@(() => Delete(fund.Id))">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>