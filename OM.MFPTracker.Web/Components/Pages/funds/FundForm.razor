@* @using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services
@using OM.MFPTracker.Data.Models
@inject IAmcRepo AmcRepo
@inject IMFCategoryRepo CategoryRepo
@inject IOperationalStatusRepo StatusRepo
@inject IMutualFundRepo FundRepo

@code {

    [Parameter] public int? EditId { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private MutualFund Fund = new();
    private List<Amc> Amcs = new();
    private List<MFCategory> Categories = new();
    private List<OperationalStatus> Statuses = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!Visible) return;

        // Load dropdowns
        Amcs = await AmcRepo.GetAllAsync();
        Categories = await CategoryRepo.GetAllAsync();
        Statuses = await StatusRepo.GetAllAsync();

        if (EditId == null)
        {
            Fund = new MutualFund();
        }
        else
        {
            var dbFund = await FundRepo.GetByIdAsync(EditId.Value);

            // IMPORTANT → detach navigation props
            Fund = new MutualFund
            {
                Id = dbFund!.Id,
                SchemeCode = dbFund.SchemeCode,
                SchemeName = dbFund.SchemeName,
                ISIN = dbFund.ISIN,
                AmcId = dbFund.AmcId,
                MFCategoryId = dbFund.MFCategoryId,
                OperationalStatusId = dbFund.OperationalStatusId
            };
        }
    }

    private async Task Save()
    {
        if (Fund.Id == 0)
            await FundRepo.AddAsync(Fund);
        else
            await FundRepo.UpdateAsync(Fund);

        await OnSaved.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task Close()
        => await OnClose.InvokeAsync();
}

@if (Visible)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        @(Fund.Id == 0 ? "Add Mutual Fund" : "Edit Mutual Fund")
                    </h5>
                    <button class="btn-close" @onclick="Close"></button>
                </div>

                <div class="modal-body">

                    <EditForm Model="Fund" OnValidSubmit="Save">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label>AMC</label>
                                <InputSelect class="form-select" @bind-Value="Fund.AmcId">
                                    <option value="">Select AMC</option>
                                    @foreach (var a in Amcs)
                                    {
                                        <option value="@a.Id">@a.Name</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label>Category</label>
                                <InputSelect class="form-select" @bind-Value="Fund.MFCategoryId">
                                    @foreach (var c in Categories)
                                    {
                                        <option value="@c.Id">@c.CategoryName</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label>Status</label>
                                <InputSelect class="form-select" @bind-Value="Fund.OperationalStatusId">
                                    @foreach (var s in Statuses)
                                    {
                                        <option value="@s.Id">@s.Description</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label>Scheme Code</label>
                                <InputText class="form-control" @bind-Value="Fund.SchemeCode" />
                            </div>

                            <div class="col-md-4">
                                <label>ISIN</label>
                                <InputText class="form-control" @bind-Value="Fund.ISIN" />
                            </div>

                            <div class="col-md-12">
                                <label>Scheme Name</label>
                                <InputText class="form-control" @bind-Value="Fund.SchemeName" />
                            </div>

                        </div>

                        <div class="mt-4 text-end">
                            <button class="btn btn-secondary me-2" type="button" @onclick="Close">Cancel</button>
                            <button class="btn btn-success">Save</button>
                        </div>

                    </EditForm>

                </div>
            </div>
        </div>
    </div>
}


 *@

@page "/folios/new"
@page "/folios/edit/{Id:int}"

@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services

@inject IFolioRepo Repo
@inject IAmcRepo AmcRepo
@inject IFolioHolder HolderRepo
@inject NavigationManager Nav

<h3 class="mb-4">
    @(Id == null ? "Add Folio" : "Edit Folio")
</h3>

<EditForm Model="model" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card shadow-sm p-4">

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Folio Name</label>
                <InputText class="form-control" @bind-Value="model.FolioName" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Purpose</label>
                <InputText class="form-control" @bind-Value="model.FolioPurpose" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputText class="form-control" @bind-Value="model.FolioDescription" />
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">AMC</label>
                <InputSelect class="form-select" @bind-Value="model.AmcId">
                    <option value="">-- Select AMC --</option>
                    @foreach (var a in amcs)
                    {
                        <option value="@a.Id">@a.Code</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Holder</label>
                <InputSelect class="form-select" @bind-Value="model.FolioHolderId">
                    <option value="">-- Select Holder --</option>
                    @foreach (var h in holders)
                    {
                        <option value="@h.Id">@h.FirstName</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input"
                           @bind-Value="model.FolioIsActive" />
            <label class="form-check-label">
                Active
            </label>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success me-2">
                Save
            </button>

            <button type="button"
                    class="btn btn-secondary"
                    @onclick="@(() => Nav.NavigateTo("/folios"))">
                Cancel
            </button>
        </div>

    </div>
</EditForm>

@code {

    [Parameter]
    public int? Id { get; set; }

    private Folio model = new();
    private List<Amc> amcs = new();
    private List<FolioHolder> holders = new();

    protected override async Task OnInitializedAsync()
    {
        amcs = await AmcRepo.GetAllAsync();
        holders = await HolderRepo.GetAllAsync();

        if (Id.HasValue)
        {
            var existing = await Repo.GetByIdAsync(Id.Value);
            if (existing != null)
                model = existing;
        }
    }

    private async Task Save()
    {
        if (model.FolioId == 0)
            await Repo.AddAsync(model);
        else
            await Repo.UpdateAsync(model);

        Nav.NavigateTo("/folios");
    }
}