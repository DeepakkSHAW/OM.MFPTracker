@* @page "/folios"
@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services

@inject IFolioRepo Repo
@inject IAmcRepo AmcRepo
@inject IFolioHolder HolderRepo
@inject NavigationManager Nav


@code {

    private List<Folio> list = new();
    private Folio model = new();

    private int pageNumber = 1;
    private int pageSize = 5;
    private int totalPages = 1;
    private int totalRecords = 0;

    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        var result = await Repo.GetPagedAsync(pageNumber, pageSize);

        list = result.Items;
        totalRecords = result.TotalCount;

        totalPages = (int)Math.Ceiling(
            totalRecords / (double)pageSize);

        if (totalPages == 0)
            totalPages = 1;
    }

    private void NewFolio()
    {
        model = new Folio();
        showModal = true;
    }
    private void Test()
    {
        showModal = true;
    }
    private void Edit(Folio f)
    {
        model = new Folio
        {
            FolioId = f.FolioId,
            FolioName = f.FolioName,
            FolioDescription = f.FolioDescription,
            FolioPurpose = f.FolioPurpose,
            AttachedBank = f.AttachedBank,
            FolioIsActive = f.FolioIsActive,
            AmcId = f.AmcId,
            FolioHolderId = f.FolioHolderId
        };

        showModal = true;
    }

    private async Task Delete(int id)
    {
        await Repo.DeleteAsync(id);

        // Adjust page if last record deleted
        if (list.Count == 1 && pageNumber > 1)
            pageNumber--;

        await Load();
    }

    private async Task OnSaved()
    {
        showModal = false;
        await Load();
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task NextPage()
    {
        if (pageNumber < totalPages)
        {
            pageNumber++;
            await Load();
        }
    }

    private async Task PrevPage()
    {
        if (pageNumber > 1)
        {
            pageNumber--;
            await Load();
        }
    }
}

<h3 class="mb-4">Folio Management</h3>

<div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-primary" @onclick="NewFolio">
        + Add Folio
    </button>
        <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/folios/new"))">+ Add Folio</button>
    <span class="text-muted small">
        Total Records: @totalRecords
    </span>
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-light">
        <tr>
            <th>Folio</th>
            <th>AMC</th>
            <th>Holder</th>
            <th>Status</th>
            <th>Created</th>
            <th style="width:140px;"></th>
        </tr>
    </thead>
    <tbody>
        @if (list.Any())
        {
            @foreach (var f in list)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@f.FolioName</div>
                        <div class="text-muted small">@f.FolioDescription</div>
                    </td>

                    <td>
                        <span class="badge bg-light text-dark border">
                            @f.Amc?.Code
                        </span>
                    </td>

                    <td>@f.FolioHolder?.FirstName</td>

                    <td>
                        <span class="badge @(f.FolioIsActive ? "bg-success" : "bg-secondary")">
                            @(f.FolioIsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td class="text-muted small">
                        @f.InDate.ToLocalTime().ToString("dd-MMM-yyyy")
                    </td>

                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-warning me-2"
                                @onclick="() => Edit(f)">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => Delete(f.FolioId)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No folios available.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
@if (totalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>
            Page @pageNumber of @totalPages
        </div>

        <div>
            <button class="btn btn-sm btn-outline-secondary me-2"
                    disabled="@(pageNumber == 1)"
                    @onclick="PrevPage">
                Prev
            </button>

            <button class="btn btn-sm btn-outline-secondary"
                    disabled="@(pageNumber == totalPages)"
                    @onclick="NextPage">
                Next
            </button>
        </div>
    </div>
}

@if (showModal)
{
    <FolioForm Folio="model"
               OnSaved="OnSaved"
               OnCancelled="CloseModal" />
}
