@page "/folios"

@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services

@inject IFolioRepo Repo
@inject NavigationManager Nav
@code {

    private List<Folio> list = new();

    private int pageNumber = 1;
    private int pageSize = 5;
    private int totalRecords = 0;

    private string searchTerm = string.Empty;

    private string sortColumn = "FolioName";
    private bool sortAscending = true;

    private int TotalPages =>
        (int)Math.Ceiling((double)totalRecords / pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadFolios();
    }

    private async Task LoadFolios()
    {
        var result = await Repo.GetPagedAsync(
            pageNumber,
            pageSize,
            searchTerm,
            sortColumn,
            sortAscending);

        list = result.Items;
        totalRecords = result.TotalCount;
    }

    private async Task Search()
    {
        pageNumber = 1;
        await LoadFolios();
    }

    private async Task SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        pageNumber = 1;
        await LoadFolios();
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        pageNumber = page;
        await LoadFolios();
    }

    private async Task Delete(int id)
    {
        await Repo.DeleteAsync(id);

        if (list.Count == 1 && pageNumber > 1)
            pageNumber--;

        await LoadFolios();
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
            return (MarkupString)"";

        return sortAscending
            ? (MarkupString)" ▲"
            : (MarkupString)" ▼";
    }
}
<h3 class="mb-4">Folio Management</h3>

<div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-primary"
            @onclick="@(() => Nav.NavigateTo("/folios/new"))">
        + Add Folio
    </button>

    <span class="text-muted small">
        Total Records: @totalRecords
    </span>
</div>

<!-- Search -->
<div class="row mb-3">
    <div class="col-md-4">
        <input type="text"
               class="form-control"
               placeholder="Search by name, AMC or holder..."
               @bind="searchTerm"
               @bind:event="oninput" />
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary"
                @onclick="Search">
            Search
        </button>
    </div>
</div>

<!-- Table -->
<table class="table table-hover align-middle shadow-sm">
    <thead class="table-light">
        <tr>
            <th style="cursor:pointer"
                @onclick="@(async () => await SortBy("FolioName"))">
                Folio Name @SortIcon("FolioName")
            </th>

            <th style="cursor:pointer"
                @onclick="@(async () => await SortBy("Amc"))">
                AMC @SortIcon("Amc")
            </th>

            <th style="cursor:pointer"
                @onclick="@(async () => await SortBy("Holder"))">
                Holder @SortIcon("Holder")
            </th>

            <th>Status</th>
            <th>Created</th>
            <th style="width:140px;"></th>
        </tr>
    </thead>

    <tbody>
        @if (list.Any())
        {
            @foreach (var f in list)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@f.FolioName</div>
                        <div class="text-muted small">@f.FolioDescription</div>
                    </td>

                    <td>
                        <span class="badge bg-light text-dark border">
                            @f.Amc?.Code
                        </span>
                    </td>

                    <td>@f.FolioHolder?.FirstName</td>

                    <td>
                        <span class="badge @(f.FolioIsActive ? "bg-success" : "bg-secondary")">
                            @(f.FolioIsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td class="text-muted small">
                        @f.InDate.ToLocalTime().ToString("dd-MMM-yyyy")
                    </td>

                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-warning me-2"
                                @onclick="@(() => Nav.NavigateTo($"/folios/edit/{f.FolioId}"))">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="async () => await Delete(f.FolioId)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No folios available.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
@if (TotalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">

        <div>
            Page @pageNumber of @TotalPages
        </div>

        <div>
            <button class="btn btn-sm btn-outline-secondary me-2"
                    disabled="@(pageNumber == 1)"
                    @onclick="async () => await ChangePage(pageNumber - 1)">
                Prev
            </button>

            <button class="btn btn-sm btn-outline-secondary"
                    disabled="@(pageNumber == TotalPages)"
                    @onclick="async () => await ChangePage(pageNumber + 1)">
                Next
            </button>
        </div>

    </div>
}

