@page "/categories"
@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services

@inject IMFCategoryRepo Repo
@inject IJSRuntime JS

<h3>Mutual Fund Categories</h3>

<div class="card mb-4">
    <div class="card-header">
        @(editing ? "Edit Category" : "Add New Category")
    </div>
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">Category Name</label>
                    <InputText class="form-control"
                               @bind-Value="model.CategoryName" />
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-success me-2" type="submit">
                    @(editing ? "Update" : "Save")
                </button>

                @if (editing)
                {
                    <button class="btn btn-secondary" type="button" @onclick="Cancel">
                        Cancel
                    </button>
                }
            </div>
        </EditForm>
    </div>
</div>

<table class="table table-hover table-sm align-middle">
    <thead class="table-light">
        <tr>
            <th>Category Name</th>
            <th style="width:150px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in categories)
        {
            <tr>
                <td>@cat.CategoryName</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-warning me-2" @onclick="() => Edit(cat)">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => Delete(cat.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<MFCategory> categories = new();
    private MFCategory model = new();
    private bool editing;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await Repo.GetAllAsync();
    }

    private void Edit(MFCategory cat)
    {
        model = new MFCategory
        {
            Id = cat.Id,
            CategoryName = cat.CategoryName
        };
        editing = true;
    }

    private void Cancel()
    {
        model = new MFCategory();
        editing = false;
    }

    private async Task Save()
    {
        if (!await Repo.IsUniqueAsync(model.Id, model.CategoryName))
        {
            await JS.InvokeVoidAsync("alert", "Category already exists!");
            return;
        }

        if (editing)
            await Repo.UpdateAsync(model);
        else
            await Repo.AddAsync(model);

        Cancel();
        await LoadCategories();
    }

    private async Task Delete(int id)
    {
        if (await Repo.IsUsedAsync(id))
        {
            await JS.InvokeVoidAsync("alert", "Cannot delete: Category is used by mutual funds.");
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", "Delete this category?"))
            return;

        await Repo.DeleteAsync(id);
        await LoadCategories();
    }
}
