@page "/operational-status"
@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services
@inject NavigationManager Navigation
@inject IOperationalStatusRepo Repo
@inject IJSRuntime JS



@code {
    private List<OperationalStatus> list = new();
    private OperationalStatus model = new();
    private bool editing = false;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        list = await Repo.GetAllOrderedAsync();
        model = new OperationalStatus();
        editing = false;
    }

    private void Edit(OperationalStatus status)
    {
        model = new OperationalStatus
        {
            Id = status.Id,
            Code = status.Code,
            Description = status.Description,
            IsTransactionAllowed = status.IsTransactionAllowed,
            IsNavAllowed = status.IsNavAllowed
        };
        editing = true;
    }
    private void Cancel()
    {
        model = new OperationalStatus();
        editing = false;
    }
    private async Task Save()
    {
        if (!await Repo.IsUniqueAsync(model.Id, model.Code))
        {
            await JS.InvokeVoidAsync("alert", "Code must be unique!");
            return;
        }

        if (editing)
            await Repo.UpdateAsync(model);
        else
            await Repo.AddAsync(model);

        await Load();
    }

    private async Task Delete(int id)
    {
        if (await Repo.IsUsedAsync(id))
        {
            await JS.InvokeVoidAsync("alert", "Cannot delete, already used by Mutual Fund!");
            return;
        }

        if (await JS.InvokeAsync<bool>("confirm", "Are you sure to delete?"))
        {
            await Repo.DeleteAsync(id);
            await Load();
        }
    }
}

<h3 class="mb-3">Operational Status</h3>

<div class="card mb-4">
    <div class="card-header">@((editing ? "Edit" : "Add New") + " Operational Status")</div>
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Code</label>
                    <InputText class="form-control" @bind-Value="model.Code" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Description</label>
                    <InputText class="form-control" @bind-Value="model.Description" />
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <InputCheckbox class="form-check-input me-1" @bind-Value="model.IsTransactionAllowed" />
                    <label class="form-check-label">Transactions Allowed</label>
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <InputCheckbox class="form-check-input me-1" @bind-Value="model.IsNavAllowed" />
                    <label class="form-check-label">NAV Allowed</label>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-success me-2" type="submit">@((editing ? "Update" : "Save"))</button>
                @if (editing)
                {
                    <button class="btn btn-secondary" type="button" @onclick="Cancel">Cancel</button>
                }
            </div>
        </EditForm>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr>
            <th style="width:80px;">Code</th>
            <th>Description</th>
            <th style="width:120px;">Transactions</th>
            <th style="width:80px;">NAV</th>
            <th style="width:130px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in list)
        {
            <tr>
                <td>@item.Code</td>
                <td>@item.Description</td>
                <td>@(item.IsTransactionAllowed ? "Yes" : "No")</td>
                <td>@(item.IsNavAllowed ? "Yes" : "No")</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => Edit(item)">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>