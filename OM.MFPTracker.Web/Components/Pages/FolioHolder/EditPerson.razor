@page "/edit-person/{Id:int}"
@using OM.MFPTracker.Data.Models
@using OM.MFPTracker.Data.Services
@inject IFolioHolder FolioHoderRepo
@inject NavigationManager Navigation

<h3>EditPerson</h3>

@code {
    [Parameter] public int Id { get; set; }

    private FolioHolder? person;

    protected override async Task OnInitializedAsync()
    {
        person = await FolioHoderRepo.GetByIdAsync(Id);
    }

    private async Task HandleValidSubmit()
    {
        if (person != null)
        {
            await FolioHoderRepo.UpdateAsync(person);
            Navigation.NavigateTo("/people");
        }
    }

    private async Task DeletePerson()
    {
        if (person != null)
        {
            await FolioHoderRepo.DeleteAsync(person.Id);
            Navigation.NavigateTo("/people");
        }
    }
}

@if (person == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="person" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>First Name</label>
            <InputText class="form-control" @bind-Value="person.FirstName" />
        </div>

        <div class="mb-3">
            <label>Last Name</label>
            <InputText class="form-control" @bind-Value="person.LastName" />
        </div>

        <div class="mb-3">
            <label>Date of Birth</label>
            <InputDate class="form-control" @bind-Value="person.DateOfBirth" />
        </div>

        <button type="submit" class="btn btn-primary">Update</button>
        <button type="button" class="btn btn-danger" @onclick="DeletePerson">Delete</button>
    </EditForm>
}