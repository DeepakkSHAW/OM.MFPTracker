@inject NavigationManager Navigation

<div class="nav-scrollable">
    <nav class="nav flex-column">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill"></span> Home
            </NavLink>
        </div>

        <!-- People Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="TogglePeople">
                <span><span class="oi oi-people"></span> People</span>
                <span class="chevron @(isPeopleOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isPeopleOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="people">List People</NavLink>
                    <NavLink class="nav-link" href="add-person">Add Person</NavLink>
                </div>
            }
        </div>

        <!-- Mutual Funds Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleFunds">
                <span><span class="oi oi-people"></span> Mutual Funds</span>
                <span class="chevron @(isFundsOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isFundsOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="operational-status">operational status</NavLink>
                    <NavLink class="nav-link" href="amclanding">AMC</NavLink>
                    <NavLink class="nav-link" href="categories">Categories</NavLink>
                    <NavLink class="nav-link" href="funds">Funds</NavLink>
                </div>
            }
        </div>

        <!-- NAVs Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleNavs">
                <span><span class="oi oi-people"></span> NAVs</span>
                <span class="chevron @(isNavsOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isNavsOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="navs">NAV List</NavLink>
                    <NavLink class="nav-link" href="/navs/navimport">Nav Import</NavLink>
                    <NavLink class="nav-link" href="special-events">Special Events</NavLink>
                </div>
            }
        </div>

    </nav>
</div>

@code {
    private bool isPeopleOpen;
    private bool isFundsOpen;
    private bool isNavsOpen;

    protected override void OnInitialized()
    {
        // Auto-expand group based on current route
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri.StartsWith("people", StringComparison.OrdinalIgnoreCase)) isPeopleOpen = true;
        if (uri.StartsWith("funds") || uri.StartsWith("categories", StringComparison.OrdinalIgnoreCase)) isFundsOpen = true;
        if (uri.StartsWith("navs", StringComparison.OrdinalIgnoreCase)) isNavsOpen = true;
    }

    private void TogglePeople() => isPeopleOpen = !isPeopleOpen;
    private void ToggleFunds() => isFundsOpen = !isFundsOpen;
    private void ToggleNavs() => isNavsOpen = !isNavsOpen;
}

